# Copy to .env and fill in as needed. docker compose up reads this
# automatically. All values below have working defaults for local
# Docker Compose — you only need to set GROQ_API_KEY for the agent harness.

# Backend database connection (default matches the postgres service below)
DATABASE_URL=postgresql+psycopg2://mandatecheck:mandatecheck@postgres:5432/mandatecheck

# Groq API key for the LLM agent harness (LiteLLM -> Groq). Not used by
# the deterministic rules engine itself. Get a free-tier key at console.groq.com.
GROQ_API_KEY=your-groq-api-key-here

# Base URL the frontend uses to reach the backend from the browser
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Single-user demo app has no auth; this scopes the kill switch's mandate list
NEXT_PUBLIC_DEMO_USER_ID=demo-user
